SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SITE_URL=http://localhost:8888

# Meta Lead Ads webhook integration
# META_WEBHOOK_VERIFY_TOKEN : random token you choose; register it in the Meta App Dashboard under Webhooks
# META_APP_SECRET            : Meta App Secret (from App Settings → Basic) for signature verification
# META_PAGE_ACCESS_TOKEN     : Page Access Token to fetch full lead field data via Graph API (optional but recommended)
META_WEBHOOK_VERIFY_TOKEN=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# Meta Conversions API (server-side events)
# META_CAPI_ACCESS_TOKEN : generated in Events Manager → Settings → Generate Access Token
# META_DATASET_ID        : Dataset / Pixel ID from Events Manager (linked to Pixel 1575754910283247)
META_CAPI_ACCESS_TOKEN=
META_DATASET_ID=