# AWS Lambda endpoint that returns the training plan.
VITE_TRAININGPLAN_API_URL=https://w5ueny6mmlslolyiegguhmzcuq0lrnws.lambda-url.eu-west-2.on.aws/trainingplan

# BrowserRouter basename for deploying the app under a subpath.
# For production under lionhybridtraining.com/planocorrida use /planocorrida
VITE_ROUTER_BASENAME=/

# Vite build-time asset base path. Keep / for local/default builds.
# For production under /planocorrida use /planocorrida/
VITE_ASSET_BASE_PATH=/
